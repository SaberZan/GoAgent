---
import BaseLayout from '../layouts/BaseLayout.astro'

const releasesUrl = 'https://github.com/wimi321/GoAgent/releases'
const githubUrl = 'https://github.com/wimi321/GoAgent'

const locales = {
  'zh-hant': {
    lang: 'zh-Hant',
    title: 'goagent - 開源免費的專業圍棋 AI 老師',
    eyebrow: '圍棋智能體',
    headline: '開源免費的專業圍棋 AI 老師',
    body: 'goagent 會看棋盤、看候選點、看變化，把關鍵手講成普通棋友聽得懂的話。',
    cards: ['開源透明', '免費下載', 'KataGo 負責事實', 'LLM 像老師一樣講解'],
    download: '下載最新版',
    docs: '閱讀中文文檔'
  },
  en: {
    lang: 'en',
    title: 'goagent - Open-source professional Go AI teacher',
    eyebrow: 'Go / Weiqi / Baduk AI Agent',
    headline: 'An open-source, free, professional Go AI teacher',
    body: 'goagent reads the board, checks candidate moves and variations, then explains key moves in plain language.',
    cards: ['Open source', 'Free download', 'KataGo provides evidence', 'LLM explains like a teacher'],
    download: 'Download latest',
    docs: 'Read Chinese docs'
  },
  ja: {
    lang: 'ja',
    title: 'goagent - オープンソースで無料の囲碁 AI 先生',
    eyebrow: '囲碁 AI エージェント',
    headline: 'オープンソースで無料のプロ向け囲碁 AI 先生',
    body: 'goagent は盤面、候補手、変化を見て、重要な一手をわかりやすく説明します。',
    cards: ['オープンソース', '無料ダウンロード', 'KataGo が根拠を出す', 'LLM が先生のように説明'],
    download: '最新版をダウンロード',
    docs: '中国語ドキュメント'
  },
  ko: {
    lang: 'ko',
    title: 'goagent - 오픈소스 무료 전문 바둑 AI 선생님',
    eyebrow: '바둑 AI 에이전트',
    headline: '오픈소스 무료 전문 바둑 AI 선생님',
    body: 'goagent는 바둑판, 후보수, 변화도를 보고 핵심 수를 이해하기 쉬운 말로 설명합니다.',
    cards: ['오픈소스', '무료 다운로드', 'KataGo가 근거 제공', 'LLM이 선생님처럼 설명'],
    download: '최신 버전 다운로드',
    docs: '중국어 문서'
  },
  th: {
    lang: 'th',
    title: 'goagent - ครู AI หมากล้อมมืออาชีพแบบโอเพนซอร์ส',
    eyebrow: 'Go / Weiqi / Baduk AI Agent',
    headline: 'ครู AI หมากล้อมมืออาชีพ ฟรี และโอเพนซอร์ส',
    body: 'goagent อ่านกระดาน ดูตัวเลือกและลำดับต่อเนื่อง แล้วอธิบายจุดสำคัญด้วยภาษาที่เข้าใจง่าย',
    cards: ['โอเพนซอร์ส', 'ดาวน์โหลดฟรี', 'KataGo ให้หลักฐาน', 'LLM อธิบายเหมือนครู'],
    download: 'ดาวน์โหลดเวอร์ชันล่าสุด',
    docs: 'อ่านเอกสารภาษาจีน'
  },
  vi: {
    lang: 'vi',
    title: 'goagent - Giáo viên AI cờ vây chuyên nghiệp, miễn phí, mã nguồn mở',
    eyebrow: 'Go / Weiqi / Baduk AI Agent',
    headline: 'Giáo viên AI cờ vây chuyên nghiệp, miễn phí, mã nguồn mở',
    body: 'goagent đọc bàn cờ, xem nước gợi ý và biến hóa, rồi giải thích nước quan trọng bằng ngôn ngữ dễ hiểu.',
    cards: ['Mã nguồn mở', 'Tải miễn phí', 'KataGo cung cấp bằng chứng', 'LLM giải thích như giáo viên'],
    download: 'Tải bản mới nhất',
    docs: 'Đọc tài liệu tiếng Trung'
  }
}

export function getStaticPaths() {
  return ['zh-hant', 'en', 'ja', 'ko', 'th', 'vi'].map((locale) => ({ params: { locale } }))
}

const locale = Astro.params.locale as keyof typeof locales
const page = locales[locale] ?? locales.en
---
<BaseLayout title={page.title} description={page.body} lang={page.lang} canonical={`https://goagent.top/${locale}`}>
  <section class="page-hero">
    <p class="eyebrow">{page.eyebrow}</p>
    <h1>goagent</h1>
    <p class="subtitle">{page.headline}</p>
    <p class="lead">{page.body}</p>
    <div class="button-row">
      <a class="button primary" href={releasesUrl}>{page.download}</a>
      <a class="button" href={githubUrl}>GitHub</a>
      <a class="button subtle" href="/docs">{page.docs}</a>
    </div>
  </section>
  <section class="content-stack">
    <div class="grid two">
      {page.cards.map((item) => (
        <article class="card">
          <h3>{item}</h3>
          <p>goagent.top</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
