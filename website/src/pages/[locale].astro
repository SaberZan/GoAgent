export function getStaticPaths() {
  return ['zh-hant', 'en', 'ja', 'ko', 'th', 'vi'].map((locale) => ({ params: { locale } }))
}

const locale = Astro.params.locale as keyof typeof locales
const page = locales[locale] ?? locales.en
---
<BaseLayout title={page.title} description={page.description} lang={page.lang} canonical={`https://goagent.top/${locale}`} pageKey="home">
  <section class="home-hero">
    <div class="hero-copy">
      <h1>{page.h1}</h1>
      <p class="lead">{page.lead}</p>
      <div class="button-row">
        <a class="button primary" href={lizzieReleases}>{page.firstCta}</a>
        <a class="button" href={goAgentReleases}>{page.secondCta}</a>
        <a class="button subtle" href="#products">{page.differenceCta}</a>
      </div>
      <div class="trust-row" aria-label="Website highlights">
        {page.trust.map((item) => <span>{item}</span>)}
      </div>
    </div>
    <figure class="hero-art">
      <img src="/images/go-tools-hero.jpg" alt="Go board and two AI review tools" width="1600" height="914" loading="eager" decoding="async" />
    </figure>
  </section>

  <section id="products" class="section-block product-section">
    <div class="section-head centered">
      <h2>{page.productsTitle}</h2>
      <p>{page.productsLead}</p>
    </div>
    <div class="product-grid">
      {page.products.map((product) => (
        <article class={`product-panel ${product.featured ? 'featured' : ''}`}>
          <img src={product.image} alt={product.alt} width="1536" height="1152" loading="lazy" decoding="async" />
          <div class="product-copy">
            <p class="product-label">{product.label}</p>
            <h3>{product.title}</h3>
            <p>{product.summary}</p>
            <ul>{product.points.map((point) => <li>{point}</li>)}</ul>
            <div class="button-row compact">
              <a class="button primary" href={product.release}>{product.primary}</a>
              <a class="button subtle" href={product.repo}>{product.secondary}</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="workflow" class="section-block workflow-section">
    <div class="section-head">
      <div>
        <h2>{page.workflowTitle}</h2>
        <p>{page.workflowLead}</p>
      </div>
    </div>
    <div class="workflow-line">
      {page.workflow.map(([title, text], index) => (
        <article class="workflow-step">
          <span>{index + 1}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="download" class="section-block download-section">
    <div class="section-head centered">
      <h2>{page.downloadTitle}</h2>
      <p>{page.downloadLead}</p>
    </div>
    <div class="download-list">
      <article class="download-row">
        <div>
          <h3>LizzieYzy Next Releases</h3>
          <p>LizzieYzy Next QQ 299419120</p>
        </div>
        <a class="button primary" href={lizzieReleases}>{page.openReleases}</a>
      </article>
      <article class="download-row">
        <div>
          <h3>GoAgent Releases</h3>
          <p>GoAgent QQ 1030632742</p>
        </div>
        <a class="button primary" href={goAgentReleases}>{page.openReleases}</a>
      </article>
    </div>
  </section>
</BaseLayout>
