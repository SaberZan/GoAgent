---
import BaseLayout from '../layouts/BaseLayout.astro'

const goAgentReleases = 'https://github.com/wimi321/GoAgent/releases'
const lizzieReleases = 'https://github.com/wimi321/lizzieyzy-next/releases'

const tools = [
  {
    audience: '推荐先下载',
    title: 'LizzieYzy Next',
    text: '面向棋友日常复盘的专业 KataGo GUI。适合野狐昵称抓谱、快速全盘分析、胜率图和底部概览。',
    platforms: ['Windows', 'macOS', 'Linux'],
    href: lizzieReleases,
    qq: 'LizzieYzy Next QQ 299419120',
    featured: true
  },
  {
    audience: '实验功能尝鲜',
    title: 'GoAgent',
    text: '实验中的围棋智能体。适合想体验当前手讲解、KataGo 证据解释和 AI 问答工作流的用户。',
    platforms: ['Windows', 'macOS'],
    href: goAgentReleases,
    qq: 'GoAgent QQ 1030632742',
    featured: false
  }
]
---
<BaseLayout title="下载 LizzieYzy Next" description="首推下载 LizzieYzy Next 专业围棋复盘工作台；GoAgent 作为实验围棋智能体提供尝鲜版本。" pageKey="download">
  <section class="page-hero">
    <h1>下载 LizzieYzy Next</h1>
    <p class="lead">大多数用户先下载 LizzieYzy Next：它是更成熟的全盘复盘工具。GoAgent 保留为实验围棋智能体，适合想尝试 AI 讲棋的人。</p>
  </section>
  <section class="content-stack">
    <div class="grid two">
      {tools.map((tool) => (
        <article class={`download-card ${tool.featured ? 'featured' : ''}`}>
          <p class="product-label">{tool.audience}</p>
          <h2>{tool.title}</h2>
          <p>{tool.text}</p>
          <div class="download-meta">
            {tool.platforms.map((platform) => <span>{platform}</span>)}
            <span>GitHub Releases</span>
            <span>SHA256</span>
          </div>
          <p>{tool.qq}</p>
          <a class="button primary" href={tool.href}>打开 {tool.title} Releases</a>
        </article>
      ))}
    </div>
    <article class="notice">
      <h2>校验下载文件</h2>
      <p>下载前先确认项目名、版本号和文件名。首推 LizzieYzy Next；如果你下载的是 GoAgent，请确认自己要试的是实验智能体版本。</p>
      <ul>
        <li>Windows 可使用 PowerShell 的 Get-FileHash。</li>
        <li>macOS 可使用 shasum -a 256。</li>
        <li>如果文件名、版本号或校验值不一致，请回到对应项目的 GitHub Releases 重新下载。</li>
      </ul>
    </article>
  </section>
</BaseLayout>
