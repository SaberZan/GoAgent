---
import BaseLayout from '../layouts/BaseLayout.astro'

const goAgentGithub = 'https://github.com/wimi321/GoAgent'
const goAgentReleases = 'https://github.com/wimi321/GoAgent/releases'
const lizzieGithub = 'https://github.com/wimi321/lizzieyzy-next'
const lizzieReleases = 'https://github.com/wimi321/lizzieyzy-next/releases'

const products = [
  {
    title: 'LizzieYzy Next',
    label: '首推 · 专业复盘工作台',
    image: '/images/lizzieyzy-next-workbench.jpg',
    alt: 'LizzieYzy Next 全盘分析工作台',
    summary: '适合绝大多数棋友先安装。打开棋谱，看胜率曲线、目差、候选点和整盘节奏，快速找出真正值得复盘的转折点。',
    points: ['野狐昵称抓谱', '快速全盘分析', '胜率图与底部概览', 'Windows / macOS / Linux'],
    primary: '下载 LizzieYzy Next',
    secondary: '查看代码',
    release: lizzieReleases,
    repo: lizzieGithub,
    featured: true
  },
  {
    title: 'GoAgent',
    label: '实验项目 · 围棋智能体',
    image: '/images/goagent-workbench.jpg',
    alt: 'GoAgent 围棋讲解工作台',
    summary: '适合愿意尝鲜的用户。它尝试把棋盘、KataGo 证据、知识库和 AI 问答放在一起，让关键手能被讲成更自然的话。',
    points: ['当前手讲解实验', 'KataGo 证据链', 'AI 问答工作流', 'Windows / macOS'],
    primary: '试用 GoAgent',
    secondary: '查看代码',
    release: goAgentReleases,
    repo: goAgentGithub,
    featured: false
  }
]

const workflow = [
  ['下载 LizzieYzy Next', '先用成熟的 KataGo 复盘工作台打开棋谱，不需要先理解引擎参数。'],
  ['看清整盘走势', '通过胜率、目差、候选点和底部概览，快速定位真正改变局面的几手棋。'],
  ['需要讲解再试 GoAgent', '如果想让 AI 用自然语言解释关键手，再尝试 GoAgent 这个实验围棋智能体。']
]

const downloads = [
  ['LizzieYzy Next Releases', '首推下载。持续维护的 KataGo 复盘 GUI，提供 Windows、macOS、Linux 多平台发布包。', lizzieReleases, 'LizzieYzy Next QQ 299419120'],
  ['GoAgent Releases', '实验围棋智能体，适合想体验 AI 讲棋工作流的用户。', goAgentReleases, 'GoAgent QQ 1030632742']
]

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'LizzieYzy Next',
  alternateName: '专业围棋复盘工作台',
  url: 'https://goagent.top/',
  description: 'LizzieYzy Next 是面向棋友的专业 KataGo 复盘工作台；GoAgent 是实验中的围棋智能体。',
  hasPart: [
    {
      '@type': 'SoftwareApplication',
      name: 'LizzieYzy Next',
      applicationCategory: 'GameApplication',
      operatingSystem: 'Windows, macOS, Linux',
      url: lizzieGithub,
      downloadUrl: lizzieReleases,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
    },
    {
      '@type': 'SoftwareApplication',
      name: 'GoAgent',
      applicationCategory: 'EducationalApplication',
      operatingSystem: 'Windows, macOS',
      url: goAgentGithub,
      downloadUrl: goAgentReleases,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' }
    }
  ]
}
---
<BaseLayout
  title="LizzieYzy Next - 专业围棋复盘工作台"
  description="LizzieYzy Next 是首推的专业 KataGo 复盘工作台，适合棋友快速看清整盘走势；GoAgent 是实验中的围棋智能体。"
  pageKey="home"
  jsonLd={jsonLd}
>
  <section class="home-hero">
    <div class="hero-copy">
      <h1>先把一盘棋复盘清楚</h1>
      <p class="lead">
        首推 LizzieYzy Next：给棋友用的专业 KataGo 复盘工作台。下载后导入棋谱，先看清胜率、目差、候选点和整盘节奏；想尝试 AI 讲棋，再试 GoAgent。
      </p>
      <div class="button-row">
        <a class="button primary" href={lizzieReleases}>下载 LizzieYzy Next</a>
        <a class="button" href="#products">选择适合你的工具</a>
        <a class="button subtle" href={goAgentReleases}>试用 GoAgent</a>
      </div>
      <div class="trust-row" aria-label="官网要点">
        <span>首推复盘工具</span>
        <span>KataGo 分析</span>
        <span>Windows / macOS / Linux</span>
      </div>
    </div>
    <figure class="hero-art">
      <img src="/images/go-tools-hero.jpg" alt="围棋棋盘与两款 AI 复盘工具界面" width="1600" height="914" loading="eager" decoding="async" />
    </figure>
  </section>

  <section id="products" class="section-block product-section">
    <div class="section-head centered">
      <h2>大多数用户，先选 LizzieYzy Next</h2>
      <p>你要的是稳定复盘和快速定位问题手；等你想尝试自然语言讲棋，再把 GoAgent 当作实验工具探索。</p>
    </div>
    <div class="product-grid">
      {products.map((product) => (
        <article class={`product-panel ${product.featured ? 'featured' : ''}`}>
          <img src={product.image} alt={product.alt} width="1536" height="1152" loading="lazy" decoding="async" />
          <div class="product-copy">
            <p class="product-label">{product.label}</p>
            <h3>{product.title}</h3>
            <p>{product.summary}</p>
            <ul>
              {product.points.map((point) => <li>{point}</li>)}
            </ul>
            <div class="button-row compact">
              <a class="button primary" href={product.release}>{product.primary}</a>
              <a class="button subtle" href={product.repo}>{product.secondary}</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="workflow" class="section-block workflow-section">
    <div class="section-head">
      <div>
        <h2>普通棋友的正确打开方式</h2>
        <p>先完成一次清晰的全盘复盘，再决定要不要加上 AI 讲解。</p>
      </div>
    </div>
    <div class="workflow-line">
      {workflow.map(([title, text], index) => (
        <article class="workflow-step">
          <span>{index + 1}</span>
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="download" class="section-block download-section">
    <div class="section-head centered">
      <h2>免费下载</h2>
      <p>首推 LizzieYzy Next。安装包统一放在 GitHub Releases，方便校验、回滚和追踪版本。</p>
    </div>
    <div class="download-list">
      {downloads.map(([title, text, href, note]) => (
        <article class="download-row">
          <div>
            <h3>{title}</h3>
            <p>{text}</p>
            <small>{note}</small>
          </div>
          <a class="button primary" href={href}>打开 Releases</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
